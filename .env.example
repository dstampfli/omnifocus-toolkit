# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Required: your Anthropic API key (read automatically by the anthropic SDK).
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown). Delete a line to use its default.
MODEL=claude-haiku-4-5          # or claude-opus-4-8 for higher-quality/higher-cost triage
MOVE_MIN_CONFIDENCE=high        # set to `medium` to also move medium-confidence matches
CHUNK_SIZE=25                   # inbox items sent per classification API call
