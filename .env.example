# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Required: your Anthropic API key (read automatically by the anthropic SDK).
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown). Delete a line to use its default.
MODEL=claude-sonnet-5            # vision-capable model; reads PDF/image attachments
MOVE_MIN_CONFIDENCE=high         # set to `medium` to also move medium-confidence matches
CHUNK_SIZE=25                    # inbox items sent per classification API call
MAX_ATTACHMENT_BYTES=10485760    # 10 MiB: per-attachment cap; larger attachments are skipped
MAX_BATCH_ATTACHMENT_BYTES=20971520  # 20 MiB: per-API-call attachment budget
MAX_NOTE_CHARS=4000              # cleaned-note truncation length
REVIEW_TAG=reviewed              # omnifocus_task_reviewer: tag marking a reviewed task
KANBAN_TAG=Kanban                # omnifocus_task_reviewer: parent tag; Reviewed becomes its child lane
WEB_FETCH_MAX_USES=3             # omnifocus_task_reviewer: max web_fetch calls per task
REVIEW_MAX_WORKERS=5             # omnifocus_task_reviewer: task reviews to run in parallel

# Optional: X (Twitter) API v2 App-only Bearer Token. Lets the triage and
# reviewer tools read the text of an X post referenced by a task (X posts are
# login-walled, so plain web fetching can't). Create one in your X developer
# portal. Leave unset/empty to skip X fetching entirely.
X_BEARER_TOKEN=
X_FETCH_MAX_USES=25              # max X post lookups per run (shared by triage + reviewer)
